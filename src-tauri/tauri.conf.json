{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vibe-break",
  "version": "0.1.0",
  "identifier": "com.luzhong.vibe-break",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Vibe Break",
        "width": 600,
        "height": 800,
        "minWidth": 240,
        "minHeight": 320,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "shadow": false,
        "resizable": true,
        "backgroundColor": "#00000000"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "requireLiteralLeadingDot": false,
          "allow": [
            "$RESOURCE/**",
            "$RESOURCE/**/*",
            "**/*"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/assets/*.vrm",
      "resources/assets/vrma/*.vrma"
    ]
  }
}