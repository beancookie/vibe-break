# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Rust / Tauri build artifacts (root-level target, since the
# src-tauri one is already excluded by src-tauri/.gitignore).
/target/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# VRM / VRMA model assets. These are user-supplied content (often
# tens of MB each) and are shipped with the Tauri bundle from
# src-tauri/resources/, so we keep them out of the git history to
# avoid bloating the repo and hitting GitHub's 100 MB per-file limit.
*.vrm
*.vrma
