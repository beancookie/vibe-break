{
  "name": "vibe-break",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "preview": "vite preview",
    "tauri:dev": "pnpm tauri dev",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "clean": "node -e \"const fs=require('fs');['dist','node_modules','src-tauri/target'].forEach(d=>fs.rmSync(d,{recursive:true,force:true}))\"",
    "tauri": "tauri",
    "tauri:android:build": "pnpm tauri android build --apk"
  },
  "dependencies": {
    "@pixiv/three-vrm": "^3.5.4",
    "@pixiv/three-vrm-animation": "^3.5.4",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-store": "~2",
    "@threlte/core": "^8.5.16",
    "mitt": "^3.0.1",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2",
    "@tsconfig/svelte": "^5.0.4",
    "@types/three": "^0.184.1",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
